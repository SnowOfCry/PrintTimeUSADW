# =============================================================================
# .env.example — PrintTimeUSA ELT Data Warehouse
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# =============================================================================

# --- PostgreSQL (Data Warehouse) ---
POSTGRES_DB=printtime_dw
POSTGRES_USER=warehouse_user
POSTGRES_PASSWORD=changeme_warehouse

# --- pgAdmin ---
PGADMIN_EMAIL=admin@printtime.local
PGADMIN_PASSWORD=changeme_pgadmin

# --- Airflow Metadata DB (reuses the same Postgres user/db for simplicity in local dev) ---
AIRFLOW_DB_NAME=printtime_dw
AIRFLOW_DB_USER=warehouse_user
AIRFLOW_DB_PASSWORD=changeme_warehouse

# --- Airflow Admin User ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_admin
AIRFLOW_ADMIN_EMAIL=admin@printtime.local

# --- Airflow Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_generated_fernet_key_here
AIRFLOW_SECRET_KEY=your_webserver_secret_key_here

# --- dbt (inherits POSTGRES_* above; shown here for clarity) ---
DBT_HOST=postgres
DBT_PORT=5432
DBT_DATABASE=printtime_dw
DBT_USER=warehouse_user
DBT_PASSWORD=changeme_warehouse
DBT_SCHEMA=silver

# --- OLTP Source (operational database the warehouse extracts from) ---
# When the warehouse runs in Docker and the OLTP DB is on the host machine,
# set OLTP_HOST=host.docker.internal so containers can reach it.
OLTP_HOST=host.docker.internal
OLTP_PORT=5432
OLTP_DB=printtime_oltp
OLTP_USER=oltp_user
OLTP_PASSWORD=changeme_oltp

# --- SonarQube ---
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=your_sonarqube_token_here
